// 1. Defina o provedor (no seu caso, PostgreSQL)
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 2. O gerador do Cliente JS
generator client {
  provider = "prisma-client-js"
}

// 3. Seus modelos (Exemplo do Integrante 1)
model Product {
  id              Int     @id @default(autoincrement())
  nome            String
  categoria       String
  preco           Float
  tamanho         String
  disponibilidade Boolean @default(true)
}